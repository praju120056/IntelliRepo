# GitParse — Repository Intelligence Engine
# Environment Configuration
# Copy this to .env and fill in values

# ─── Data Storage ────────────────────────────────────────────────────────────
# Directory where all persistent data lives (graphs, chroma_db, workspaces).
# Defaults to ~/.gitparse on the current user's home directory.
# NEVER point this inside the project root.
# GITPARSE_DATA_DIR=C:\Users\YourUser\.gitparse

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ─── Analysis ────────────────────────────────────────────────────────────────
# Maximum depth for BFS/DFS graph traversal
MAX_TRAVERSAL_DEPTH=5

# Default top-k results from vector search
DEFAULT_TOP_K=10

# ─── Cache ───────────────────────────────────────────────────────────────────
# Hours of inactivity before a repo is evicted from cache
CACHE_TTL_HOURS=3

# Cache check interval in minutes
CACHE_CHECK_INTERVAL_MINUTES=15

# ─── Embedding Model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
